<Window x:Class="FileLoadDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:hx="http://helix-toolkit.org/wpf/SharpDX"
        xmlns:local="clr-namespace:FileLoadDemo"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="Polygon Optimizer"
        Width="1250"
        Height="800">
    <Window.InputBindings>
        <KeyBinding Key="Delete" Command="{Binding DeleteTrianglesCommand}" />
    </Window.InputBindings>
    <Grid>
        <Grid.Resources>
            <BooleanToVisibilityConverter x:Key="boolToVisibilityConverter" />
            <Style TargetType="Button">
                <Setter Property="Padding" Value="6,4" />
                <Setter Property="Background" Value="#E8E8E8" />
                <Setter Property="BorderBrush" Value="#D0D0D0" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="3"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#F0F0F0" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#C8C8C8" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="border" Property="Opacity" Value="0.5" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style x:Key="AccentButton" TargetType="Button">
                <Setter Property="Background" Value="#2E7A80" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="BorderBrush" Value="#3A9AA0" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="6,4" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="3"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#3A9AA0" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#1E5A5E" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="border" Property="Opacity" Value="0.5" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style x:Key="DangerButton" TargetType="Button">
                <Setter Property="Background" Value="#C06030" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="BorderBrush" Value="#D08050" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="6,4" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="3"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#D07040" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#A05020" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="border" Property="Opacity" Value="0.5" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <ObjectDataProvider x:Key="SelectionModeValues"
                                MethodName="GetValues"
                                ObjectType="{x:Type sys:Enum}">
                <ObjectDataProvider.MethodParameters>
                    <x:Type TypeName="local:SelectionMode" />
                </ObjectDataProvider.MethodParameters>
            </ObjectDataProvider>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition>
                    <ColumnDefinition.Style>
                        <Style TargetType="ColumnDefinition">
                            <Setter Property="Width" Value="0" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowUV}" Value="True">
                                    <Setter Property="Width" Value="*" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ColumnDefinition.Style>
                </ColumnDefinition>
            </Grid.ColumnDefinitions>
            <!-- 3D Viewport -->
            <Grid x:Name="viewportGrid" Grid.Column="0" Background="Transparent">
                <hx:Viewport3DX x:Name="view"
                                BackgroundColor="#505050"
                                Camera="{Binding Camera}"
                                EffectsManager="{Binding EffectsManager}"
                                EnableSwapChainRendering="True"
                                EnableSSAO="True"
                                MSAA="Two"
                                FXAALevel="None"
                                FixedRotationPoint="{Binding ModelCentroid}"
                                FixedRotationPointEnabled="True">
                    <hx:Viewport3DX.InputBindings>
                        <KeyBinding Key="B"
                                    Command="hx:ViewportCommands.BackView" />
                        <KeyBinding Key="F"
                                    Command="hx:ViewportCommands.FrontView" />
                        <KeyBinding Key="U"
                                    Command="hx:ViewportCommands.TopView" />
                        <KeyBinding Key="D"
                                    Command="hx:ViewportCommands.BottomView" />
                        <KeyBinding Key="L"
                                    Command="hx:ViewportCommands.LeftView" />
                        <KeyBinding Key="R"
                                    Command="hx:ViewportCommands.RightView" />
                        <KeyBinding Command="hx:ViewportCommands.ZoomExtents"
                                    Gesture="Control+E" />
                        <MouseBinding Command="hx:ViewportCommands.Rotate"
                                      Gesture="RightClick" />
                        <MouseBinding Command="hx:ViewportCommands.Zoom"
                                      Gesture="MiddleClick" />
                    </hx:Viewport3DX.InputBindings>
                    <hx:AmbientLight3D Color="#363636" />
                    <hx:DirectionalLight3D Direction="{Binding Camera.LookDirection}"
                                           Color="#D6D6D6" />
                    <hx:Element3DPresenter Content="{Binding GroupModel}" />
                    <hx:LineGeometryModel3D Geometry="{Binding WireframeGeometry}"
                                            Color="#99000000"
                                            Thickness="0.6"
                                            FixedSize="True"
                                            DepthBias="-100"
                                            SlopeScaledDepthBias="-2"
                                            IsHitTestVisible="False" />
                    <hx:MeshGeometryModel3D Geometry="{Binding SelectionMesh}" Material="{Binding SelectionMaterial}" IsTransparent="True" CullMode="None" IsHitTestVisible="False" />
                    <hx:LineGeometryModel3D Geometry="{Binding OctahedronLines}"
                                            Color="Cyan"
                                            IsRendering="{Binding ShowOctahedron}" />
                    <hx:LineGeometryModel3D Geometry="{Binding SelectionRectGeometry}"
                                            Color="Yellow"
                                            Thickness="0.75"
                                            IsHitTestVisible="False" />
                </hx:Viewport3DX>
                <Grid Background="#7B363636"
                      Visibility="{Binding IsLoading, Converter={StaticResource boolToVisibilityConverter}}">
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Orientation="Vertical">
                        <TextBlock Foreground="White">Loading Model</TextBlock>
                        <ProgressBar Width="200"
                                     Height="30"
                                     IsIndeterminate="True" />
                    </StackPanel>
                </Grid>
            </Grid>
            <!-- UV Viewport -->
            <Grid x:Name="uvGrid" Grid.Column="1" Background="#404040" ClipToBounds="True"
                  MouseLeftButtonDown="UVPanel_MouseLeftButtonDown"
                  MouseMove="UVPanel_MouseMove"
                  MouseLeftButtonUp="UVPanel_MouseLeftButtonUp"
                  MouseDown="UVPanel_MouseDown"
                  MouseUp="UVPanel_MouseUp"
                  MouseWheel="UVPanel_MouseWheel">
                <Viewbox Stretch="Uniform" RenderTransformOrigin="0.5,0.5">
                    <Viewbox.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform x:Name="uvZoom" ScaleX="1" ScaleY="1" />
                            <TranslateTransform x:Name="uvPan" />
                        </TransformGroup>
                    </Viewbox.RenderTransform>
                    <Canvas x:Name="uvCanvas" Width="1.2" Height="1.2">
                        <Canvas.Background>
                            <SolidColorBrush Color="#404040" />
                        </Canvas.Background>
                        <!-- UV border outline -->
                        <Rectangle Canvas.Left="0.1" Canvas.Top="0.1" Width="1" Height="1"
                                   Stroke="#555555" StrokeThickness="0.002" />
                        <Canvas Canvas.Left="0.1" Canvas.Top="0.1">
                            <Path Data="{Binding UvSelectionFill}" Fill="#80FFFF00" />
                            <Path Data="{Binding UvWireframe}" Stroke="#AAFFFFFF" StrokeThickness="0.002" />
                        </Canvas>
                        <Path x:Name="uvSelectionRect" Stroke="Yellow" StrokeThickness="0.002" />
                    </Canvas>
                </Viewbox>
            </Grid>
        </Grid>
        <Menu Grid.Row="0"
              Height="20"
              VerticalAlignment="Top">
            <MenuItem Header="File">
                <MenuItem Command="{Binding OpenFileCommand}"
                          Header="Open File" />
                <MenuItem Command="{Binding CloseFileCommand}"
                          Header="Close File" />
                <MenuItem Command="{Binding ExportCommand}"
                          Header="Export" />
                <Separator />
                <MenuItem Header="Exit" Click="Exit_Click" />
            </MenuItem>
            <MenuItem Header="View">
                <MenuItem Header="Show UV"
                          IsCheckable="True"
                          IsChecked="{Binding ShowUV}" />
            </MenuItem>
            <MenuItem Header="Edit">
                <MenuItem Command="{Binding CopyAsBitmapCommand}"
                          Header="Copy As Bitmap (Window Size)" />
                <MenuItem Command="{Binding CopyAsHiresBitmapCommand}"
                          Header="Copy as Hiresolution Bitmap (1920x1080)" />
            </MenuItem>
        </Menu>

        <ScrollViewer Grid.Row="1"
                      Grid.Column="1"
                      Width="250"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="2">
                <!-- Stats -->
                <Border Background="#2E7A80" BorderBrush="#3A9AA0" BorderThickness="1" CornerRadius="3" Margin="2" Padding="8">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold"
                                   Foreground="White" FontSize="14" Margin="0,0,0,10">Num Triangles Selected</TextBlock>
                        <TextBlock Foreground="White"
                                   FontSize="16"
                                   FontFamily="Consolas">
                            <Run FontWeight="Bold" Text="{Binding SelectedCountText, Mode=OneWay}" />
                            <Run Text=" / " />
                            <Run Text="{Binding TotalCountText, Mode=OneWay}" />
                            <Run Text=" " />
                            <Run FontWeight="Bold" Text="{Binding SelectedPercentText, Mode=OneWay}" />
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Selection -->
                <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="3" Margin="2" Padding="8">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold" Foreground="#2E7A80" FontSize="14" Margin="0,0,0,10">Selection Mode</TextBlock>
                        <ComboBox Margin="0,2"
                                  SelectedItem="{Binding SelectionMode}"
                                  ItemsSource="{Binding Source={StaticResource SelectionModeValues}}" />
                        <StackPanel Margin="0,2" Orientation="Horizontal"
                                    Visibility="{Binding IsViewSelectionMode, Converter={StaticResource boolToVisibilityConverter}}">
                            <TextBlock VerticalAlignment="Center">Threshold (%):</TextBlock>
                            <TextBox Width="50" Margin="4,0" Text="{Binding OcclusionThreshold, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <Button Margin="0,2"
                                Command="{Binding SelectCurrentViewCommand}"
                                Visibility="{Binding IsViewSelectionMode, Converter={StaticResource boolToVisibilityConverter}}">
                            Select Current View
                        </Button>
                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Margin="0,0,2,0"
                                    Command="{Binding InvertVisibleSelectionCommand}">Invert</Button>
                            <Button Grid.Column="1" Margin="2,0,0,0"
                                    Command="{Binding ClearVisibleSelectionCommand}">Deselect</Button>
                        </Grid>
                        <CheckBox Margin="0,4" IsChecked="{Binding IgnoreBackfacing}">Ignore Backfacing</CheckBox>
                        <CheckBox Margin="0,2" IsChecked="{Binding SelectConnected}">Select Connected</CheckBox>
                    </StackPanel>
                </Border>

                <!-- Iterate Views -->
                <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="3" Margin="2" Padding="8">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold" Foreground="#2E7A80" FontSize="14" Margin="0,0,0,10">Iterate Views</TextBlock>
                        <CheckBox Margin="0,2" IsChecked="{Binding ShowOctahedron}">Show Octahedron</CheckBox>
                        <StackPanel Margin="0,2" Orientation="Horizontal">
                            <TextBlock VerticalAlignment="Center">Resolution:</TextBlock>
                            <TextBox Width="40" Margin="4,0"
                                     Text="{Binding OctahedronResolution, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Margin="0,2" Orientation="Horizontal">
                            <TextBlock VerticalAlignment="Center">Camera Width:</TextBlock>
                            <TextBox Width="50" Margin="4,0"
                                     Text="{Binding IterateCameraWidth, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <Button Margin="0,2" Command="{Binding IterateViewsCommand}" Style="{StaticResource AccentButton}">Iterate Views</Button>
                        <StackPanel Margin="0,4" Orientation="Horizontal">
                            <TextBlock VerticalAlignment="Center">View:</TextBlock>
                            <TextBlock VerticalAlignment="Center" Margin="4,0"
                                       Text="{Binding ViewPreviewIndex}" />
                            <TextBlock VerticalAlignment="Center" Text="/" />
                            <TextBlock VerticalAlignment="Center"
                                       Text="{Binding OctahedronVertexCount}" />
                        </StackPanel>
                        <Slider Margin="0,2"
                                Minimum="0"
                                Maximum="{Binding ViewPreviewMax}"
                                Value="{Binding ViewPreviewIndex}"
                                SmallChange="1"
                                LargeChange="1"
                                IsSnapToTickEnabled="True"
                                TickFrequency="1" />
                    </StackPanel>
                </Border>

                <!-- Edit Geometry -->
                <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="3" Margin="2" Padding="8">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold" Foreground="#2E7A80" FontSize="14" Margin="0,0,0,10">Edit Geometry</TextBlock>
                        <Button Margin="0,2" Command="{Binding DeleteTrianglesCommand}" Style="{StaticResource DangerButton}">Delete Triangles</Button>
                        <Button Margin="0,2" Command="{Binding UndoCommand}">Undo</Button>
                    </StackPanel>
                </Border>

                <!-- Materials -->
                <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="3" Margin="2" Padding="8">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold" Foreground="#2E7A80" FontSize="14" Margin="0,0,0,10">Materials</TextBlock>
                        <ItemsControl ItemsSource="{Binding MaterialItems}" MaxHeight="150">
                            <ItemsControl.Template>
                                <ControlTemplate TargetType="ItemsControl">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </ControlTemplate>
                            </ItemsControl.Template>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Margin="2" IsChecked="{Binding IsVisible}" Content="{Binding Name}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Display -->
                <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="3" Margin="2" Padding="8">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold" Foreground="#2E7A80" FontSize="14" Margin="0,0,0,10">Display</TextBlock>
                        <Button Command="{Binding ResetCameraCommand}">Reset Camera</Button>
                        <CheckBox Margin="0,4" IsChecked="{Binding ShowWireframe}">Show Wireframe</CheckBox>
                        <CheckBox Margin="0,2" IsChecked="{Binding RenderFlat}">Flat Shading</CheckBox>
                        <CheckBox Margin="0,2" IsChecked="{Binding XRayMode}">X-Ray Mode</CheckBox>
                        <CheckBox Margin="0,2" IsChecked="{Binding ShowBackface}">Show Backface</CheckBox>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="1"
              Grid.Column="2"
              Width="250"
              VerticalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <StackPanel Margin="2">
                <!-- Animations -->
                <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="3" Margin="2" Padding="8">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold" Foreground="#2E7A80" FontSize="14" Margin="0,0,0,10">Animations</TextBlock>
                        <ComboBox Margin="0,2"
                                  DisplayMemberPath="Name"
                                  IsEnabled="{Binding ElementName=aniCheckbox, Path=IsChecked}"
                                  ItemsSource="{Binding Animations}"
                                  SelectedItem="{Binding SelectedAnimation}" />
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <Label Content="Speed:" Padding="0,0,4,0" VerticalAlignment="Center" />
                            <TextBlock VerticalAlignment="Center" Text="{Binding Speed}" />
                            <Button Margin="4,0,0,0" Command="{Binding PlayCommand}">Play</Button>
                        </StackPanel>
                        <Slider Maximum="50" Minimum="0" SmallChange="0.5" Value="{Binding Speed}" />
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <TextBlock VerticalAlignment="Center">TimeStamp:</TextBlock>
                            <TextBlock VerticalAlignment="Center" Margin="4,0" Text="{Binding CurrAnimationTime}" />
                        </StackPanel>
                        <Slider LargeChange="1"
                                Maximum="{Binding EndTime}"
                                Minimum="{Binding StartTime}"
                                SmallChange="0.1"
                                Value="{Binding CurrAnimationTime}" />
                    </StackPanel>
                </Border>
            </StackPanel>
            <!-- Scene Graph -->
            <Border Grid.Row="1" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="3" Margin="4,2" Padding="4">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" FontWeight="SemiBold" Foreground="#2E7A80" FontSize="14" Margin="0,0,0,10">Scene Graph</TextBlock>
                    <Button DockPanel.Dock="Top" Margin="0,0,0,4"
                            Command="{Binding DeleteSceneNodeCommand}"
                            Focusable="False">Set As Root</Button>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <TreeView ItemsSource="{Binding GroupModel.GroupNode.Items}">
                            <TreeView.ItemContainerStyle>
                                <Style TargetType="TreeViewItem">
                                    <Setter Property="IsSelected"
                                            Value="{Binding Tag.Selected, Mode=TwoWay}" />
                                    <Setter Property="IsExpanded"
                                            Value="{Binding Tag.Expanded, Mode=TwoWay}" />
                                </Style>
                            </TreeView.ItemContainerStyle>
                            <TreeView.ItemTemplate>
                                <HierarchicalDataTemplate ItemsSource="{Binding Items}">
                                    <TextBlock Text="{Binding Name}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Setters>
                                                    <Setter Property="Foreground" Value="Black" />
                                                </Style.Setters>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsAnimationNode}" Value="true">
                                                        <Setter Property="Foreground" Value="Blue" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </HierarchicalDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
